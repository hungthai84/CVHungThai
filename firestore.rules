rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validation helper
    function isValidUser(data) {
      return data.keys().hasAll(['createdAt']) &&
             data.keys().size() <= 2 &&
             (data.keys().hasAny(['email']) ? data.email is string && data.email.size() <= 100 : true) &&
             data.createdAt == request.time;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if false; // Immutable for now
      allow delete: if false;
    }
  }
}
